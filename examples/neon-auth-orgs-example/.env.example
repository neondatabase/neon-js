# Neon Auth (get from Neon Console -> Project -> Auth -> Configuration)
NEON_AUTH_BASE_URL=https://your-endpoint.neonauth.us-east-1.aws.neon.tech/neondb/auth
NEON_AUTH_COOKIE_SECRET=generate-with-openssl-rand-base64-32

# Neon Database (get from Neon Console -> Connection Details)
DATABASE_URL=postgresql://neondb_owner:password@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
