NEON_AUTH_BASE_URL=https://ep-xxx.neonauth.us-east-1.aws.neon.tech/neondb/auth
DATABASE_URL=
NEON_AUTH_COOKIE_SECRET=REPLACE_WITH_RANDOM_SECRET_AT_LEAST_32_CHARS
# Webhook secret used by the example's EdDSA signature verification in app/api/webhooks/neon-auth/route.ts.
# Leave unset or set to "whsec_local_dev_secret" to bypass signature verification for local dev.
# In real deployments, set this to the secret configured on the Neon Auth project's webhook config.
NEON_AUTH_WEBHOOK_SECRET=
