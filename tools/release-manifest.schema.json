{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/neondatabase/neon-js/tools/release-manifest.schema.json",
  "title": "Release Manifest",
  "description": "Contract between neon-js prepare-release (stage 1) and the secure publishing repo (stage 2). The secure repo validates all downloaded bundles against this schema before scanning or publishing.",
  "type": "object",
  "required": [
    "schemaVersion",
    "sourceRepo",
    "sourceCommitSha",
    "sourceBranch",
    "triggerEvent",
    "prepareWorkflowName",
    "prepareRunId",
    "prepareRunAttempt",
    "generatedAt",
    "packages"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "1",
      "description": "Schema version for forward compatibility."
    },
    "sourceRepo": {
      "type": "string",
      "description": "Full owner/repo slug, e.g. neondatabase/neon-js."
    },
    "sourceCommitSha": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$",
      "description": "Full 40-char SHA of the commit being released."
    },
    "sourceBranch": {
      "type": "string",
      "description": "Branch name at prepare time, e.g. main."
    },
    "triggerEvent": {
      "type": "string",
      "description": "GitHub Actions event name that triggered the prepare workflow (e.g. push, workflow_dispatch)."
    },
    "prepareWorkflowName": {
      "type": "string",
      "description": "Name of the prepare workflow file, e.g. prepare-release.yml."
    },
    "prepareRunId": {
      "type": "string",
      "description": "GitHub Actions run ID of the prepare workflow."
    },
    "prepareRunAttempt": {
      "type": "string",
      "description": "GitHub Actions run attempt number."
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of manifest generation."
    },
    "packages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/PackageEntry"
      },
      "description": "Ordered list of packages to publish. Order matches publishOrder (leaves first)."
    }
  },
  "$defs": {
    "PackageEntry": {
      "type": "object",
      "required": [
        "packageId",
        "packageName",
        "packageDir",
        "currentVersion",
        "nextVersion",
        "bumpType",
        "directChange",
        "publishOrder",
        "tagName",
        "tarballFilename",
        "internalDependencyUpdates"
      ],
      "additionalProperties": false,
      "properties": {
        "packageId": {
          "type": "string",
          "description": "Short package identifier, e.g. auth-ui."
        },
        "packageName": {
          "type": "string",
          "description": "Full npm package name, e.g. @neondatabase/auth-ui."
        },
        "packageDir": {
          "type": "string",
          "description": "Relative path from repo root, e.g. packages/auth-ui."
        },
        "currentVersion": {
          "type": "string",
          "description": "Version in package.json before the bump."
        },
        "nextVersion": {
          "type": "string",
          "description": "Computed next version to publish."
        },
        "bumpType": {
          "type": "string",
          "enum": ["patch", "minor", "major"],
          "description": "Semver bump applied (direct or cascaded)."
        },
        "directChange": {
          "type": "boolean",
          "description": "True if this package had direct file changes since last tag."
        },
        "cascadeFrom": {
          "type": ["string", "null"],
          "description": "PackageId that triggered this cascade bump, or null if direct."
        },
        "publishOrder": {
          "type": "integer",
          "minimum": 0,
          "description": "Publish sequence index (0-based). Leaves publish first."
        },
        "tagName": {
          "type": "string",
          "description": "Git tag to create, e.g. auth-ui-v0.2.0."
        },
        "tarballFilename": {
          "type": "string",
          "description": "Filename of the packed tarball in prepared-release/packages/."
        },
        "internalDependencyUpdates": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["dependencyName", "fromVersion", "toVersion"],
            "additionalProperties": false,
            "properties": {
              "dependencyName": {
                "type": "string",
                "description": "npm package name of the internal dependency."
              },
              "fromVersion": {
                "type": "string",
                "description": "Previous workspace version specifier."
              },
              "toVersion": {
                "type": "string",
                "description": "Exact version after cascade bump."
              }
            }
          },
          "description": "Internal workspace dependencies that were updated for this release."
        }
      }
    }
  }
}
